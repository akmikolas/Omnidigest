# ==========================
# Redis Configuration (Redis 缓存配置)
# ==========================
# Redis host address (use container name in Docker) / Redis 主机地址 (Docker 中使用容器名)
REDIS_HOST=redis
# Redis port / Redis 端口
REDIS_PORT=6379
# Redis database number / Redis 数据库编号
REDIS_DB=0
# Redis password (if required) / Redis 密码 (如有需要)
# REDIS_PASSWORD=
# Enable Redis cache / 启用 Redis 缓存
REDIS_ENABLED=true

# ==========================
# Database Configuration (数据库配置)
# ==========================
# Database host address / 数据库主机地址 (e.g., localhost, 127.0.0.1)
DB_HOST=localhost
# Database port / 数据库端口 (PostgreSQL default is 5432)
DB_PORT=5432
# Database username / 数据库用户名
DB_USER=root
# Database password / 数据库密码
DB_PASSWORD=
# Database name / 数据库名称
DB_NAME=omnidigest

# ==========================
# RAGFlow Configuration (RAGFlow 知识库配置)
# ==========================
# Enable/Disable RAGFlow integration globally / 全局启用或禁用 RAGFlow 集成
RAGFLOW_ENABLED=False
# RAGFlow API Base URL / RAGFlow API 的基础地址
RAGFLOW_API_URL=http://localhost/api/v1
# RAGFlow API Key / RAGFlow API 密钥
RAGFLOW_API_KEY=
# Default Dataset ID for general syncing / 用于普通数据同步的默认数据集 ID
RAGFLOW_DATASET_ID=

# ==========================
# External LLM Configuration (外部大语言模型配置)
# ==========================
# NOTE: LLM 配置优先从数据库读取（llm_providers 表），.env 中的配置作为备用/默认值
# Note: LLM config is primarily read from database (llm_providers table), .env config is fallback/default
# 以下配置仅在数据库中无可用配置时使用
# LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL_NAME=deepseek-chat

# ==========================
# Template Directory (模板目录)
# ==========================
# Directory containing Jinja2 notification templates / Jinja2 通知模板目录
TEMPLATE_DIR=templates

# ==========================
# Notifications (通知与分发配置)
# ==========================
# NOTE: For DingTalk robots, ensure the webhook includes the keyword "新闻" in the message
# or set up the robot to allow custom keywords. Messages without the keyword will be rejected.
# 提示: 钉钉机器人需要在消息中包含关键词"新闻"，否则消息会被拒绝。

# =============================================================================
# Telegram Robots Configuration
# =============================================================================
# TG_BOT_TOKEN is now merged into TG_ROBOTS as bot_token
# TG_ROBOTS='[{"bot_token": "YOUR_BOT_TOKEN", "chat_id": "-100YOURCHATID", "enable_daily": true, "daily_template": "telegram_default.html.j2", "enable_breaking": true, "breaking_template": "telegram_breaking.html.j2", "enable_twitter": true, "twitter_template": "telegram_twitter_alert.html.j2", "enable_astock": true, "astock_template": "telegram_astock_pre_market.html.j2"}]'
TG_ROBOTS=

# =============================================================================
# DingTalk Robots Configuration
# =============================================================================
# Example: First robot gets daily only. Second robot gets everything including A股 analysis.
# DING_ROBOTS='[{"token": "your_ding_webhook_token_here", "secret": "your_optional_ding_secret_here", "enable_daily": true, "daily_template": "dingtalk_no_critique.md.j2", "enable_breaking": false, "breaking_template": "dingtalk_breaking.md.j2", "enable_twitter": false, "twitter_template": "dingtalk_twitter_alert.md.j2", "enable_astock": false, "astock_template": "dingtalk_astock_pre_market.md.j2"}, {"token": "your_second_ding_token", "secret": "", "enable_daily": true, "daily_template": "dingtalk_default.md.j2", "enable_breaking": true, "breaking_template": "dingtalk_breaking.md.j2", "enable_twitter": true, "twitter_template": "dingtalk_twitter_alert.md.j2", "enable_astock": true, "astock_template": "dingtalk_astock_pre_market.md.j2"}]'
DING_ROBOTS=

# =============================================================================
# Feishu (飞书) Robots Configuration
# =============================================================================
# Example: Feishu robot with signature enabled
# FEISHU_ROBOTS='[{"webhook_url": "https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_WEBHOOK_ID", "secret": "YOUR_SECRET_HERE", "enable_daily": true, "daily_template": "feishu_default.md.j2", "enable_breaking": true, "breaking_template": "feishu_breaking.md.j2", "enable_twitter": true, "twitter_template": "feishu_twitter_alert.md.j2", "enable_astock": true, "astock_template": "feishu_astock.md.j2"}]'
FEISHU_ROBOTS=

# ==========================
# Scheduler & Jobs (定时任务与抓取配置)
# ==========================
# Interval in hours to fetch standard RSS feeds / 常规 RSS 源的抓取间隔 (小时)
FETCH_INTERVAL_HOURS=1
# Comma-separated hours (UTC) to trigger daily summary / 触发每日总结的小时数 (UTC 时间，逗号分隔)
SUMMARY_HOUR="0,12"
# Minute to trigger daily summary / 触发每日总结的分钟数
SUMMARY_MINUTE=0

# ==========================
# Breaking News Subsystem (突发新闻子系统)
# ==========================
# Master switch for breaking news streaming / 突发新闻流监听总开关
ENABLE_BREAKING_NEWS=True
# Enable RAGFlow vector deduplication for breaking news / 启用 RAGFlow 突发新闻向量去重
BREAKING_RAG_ENABLED=False
# RAGFlow dataset name for breaking events / 突发新闻专用的 RAGFlow 数据集名称
BREAKING_RAG_DATASET_NAME=OmniDigest Breaking Events
# RAGFlow dataset ID for breaking events / 突发新闻专用的 RAGFlow 数据集 ID (可通过命令自动创建)
BREAKING_RAG_DATASET_ID=
# Embedding model used for breaking news deduplication / 突发新闻去重使用的嵌入模型 (需带上供应商)
BREAKING_EMBEDDING_MODEL=text-embedding-v4@Tongyi-Qianwen
# Minimum vector similarity score to consider as exact match / 向量检索完全匹配的最低相似度阈值
BREAKING_RAG_SIMILARITY_THRESHOLD=0.85
# Minimum impact score (0-100) to trigger an instant alert / 触发即时警报的最低事件评分阈值
BREAKING_IMPACT_THRESHOLD=80
# Interval in minutes to fetch breaking news feeds / 突发新闻 RSS 源的抓取间隔 (分钟)
BREAKING_FETCH_INTERVAL_MINUTES=5
# Push breaking alerts to DingTalk / 是否将突发新闻推送到钉钉
BREAKING_PUSH_DINGTALK=True
# Push breaking alerts to Telegram / 是否将突发新闻推送到 Telegram
BREAKING_PUSH_TELEGRAM=True
# Maximum concurrent LLM tasks for breaking analysis / 突发新闻分析的最大并发 LLM 任务数
BREAKING_PROCESSOR_CONCURRENCY=6
# Maximum number of breaking streams to pull per batch / 每批次拉取处理的最大突发新闻条数
BREAKING_PROCESSOR_BATCH_SIZE=10
# Number of recent events to include in LLM context (optimization) / LLM 上下文中包含的最近事件数量 (优化)
BREAKING_CONTEXT_RECENT_EVENTS=3
# Number of active stories to include in LLM context (optimization) / LLM 上下文中包含的活跃故事数量 (优化)
BREAKING_CONTEXT_ACTIVE_STORIES=10
# Lookback days for story timeline clustering / 故事时间线聚类的回溯天数
BREAKING_STORY_LOOKBACK_DAYS=10

# ==========================
# Prompt Engineering (提示词工程配置)
# ==========================
# Custom override for the daily overview prompt / 覆盖每日概述的提示词
# PROMPT_OVERVIEW="..."
# Custom override for the critique/commentary prompt / 覆盖锐评/点评的提示词
# PROMPT_CRITIQUE="..."
# Custom override for the title translation prompt / 覆盖标题翻译的提示词
# PROMPT_TRANSLATE_TITLES="..."

# ==========================
# Twitter Intelligence Subsystem (v1.7+ 推特情报子系统)
# ==========================
# Master switch for Twitter alerts / 推特情报警报总开关
ENABLE_TWITTER_ALERTS=True
# Push Twitter alerts to DingTalk / 是否将推特情报推送到钉钉
TWITTER_PUSH_DINGTALK=True
# Push Twitter alerts to Telegram / 是否将推特情报推送到 Telegram
TWITTER_PUSH_TELEGRAM=True
# Minimum impact score (0-100) to trigger an alert / 触发警报的最低影响力评分阈值
TWITTER_IMPACT_THRESHOLD=80
# Time window in minutes to search for similar events / 搜索相似事件的回溯时间窗口 (分钟)
TWITTER_EVENT_LOOKBACK_MINUTES=10
# Number of sources required to trigger an event alert / 触发事件警报所需的最少来源数
TWITTER_EVENT_PUSH_THRESHOLD=2
# Automatic cooling period in minutes for accounts after rate limit / 账号触发限流后的自动冷却时间 (分钟)
TWITTER_ACCOUNT_COOLING_MINUTES=15
# Delay in seconds between each user fetch request / 每次用户请求之间的延迟 (秒)
TWITTER_REQUEST_DELAY_SECONDS=1.0

# ==========================
# Knowledge Graph (Dgraph 知识图谱配置)
# ==========================
# Enable/Disable Knowledge Graph / 启用或禁用知识图谱
KG_ENABLED=False
# Dgraph Alpha server URL / Dgraph Alpha 服务器地址
DGRAPH_ALPHA_URL=localhost:9080

# ==========================
# A-Share Market Analysis Subsystem (v1.8+ A股趋势分析子系统)
# ==========================
# Enable/Disable A股 analysis / 启用或禁用 A股分析
ENABLE_ASTOCK_ANALYSIS=True
# Pre-market analysis time (hour) / 盘前分析执行时间 (小时)
ASTOCK_PRE_MARKET_HOUR=8
# Pre-market analysis time (minute) / 盘前分析执行时间 (分钟)
ASTOCK_PRE_MARKET_MINUTE=30
# Intraday analysis time (hour) / 盘中分析执行时间 (小时)
ASTOCK_INTRADAY_HOUR=14
# Intraday analysis time (minute) / 盘中分析执行时间 (分钟)
ASTOCK_INTRADAY_MINUTE=30
# Post-market analysis time (hour) / 盘后分析执行时间 (小时)
ASTOCK_POST_MARKET_HOUR=15
# Post-market analysis time (minute) / 盘后分析执行时间 (分钟)
ASTOCK_POST_MARKET_MINUTE=30
# Push A股 analysis to Telegram / 是否将 A股分析推送到 Telegram
ASTOCK_PUSH_TELEGRAM=True
# Push A股 analysis to DingTalk / 是否将 A股分析推送到钉钉
ASTOCK_PUSH_DINGTALK=True
# Semantic similarity threshold for news filtering / 新闻语义筛选的相似度阈值
ASTOCK_SEMANTIC_THRESHOLD=0.7
# Query template for semantic news filtering / 语义新闻筛选的查询模板
ASTOCK_QUERY_TEMPLATE=A股 股市 大盘 指数 宏观经济 货币政策 财政政策 行业政策 美联储 央行 房地产 新能源 半导体
# Hours to look back for news / 回溯获取新闻的小时数
ASTOCK_NEWS_HOURS=24
